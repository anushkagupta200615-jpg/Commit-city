# Copy this file to ".env.local" and fill in your values.

# Raises GitHub's API rate limit from 60/hr to 5,000/hr.
# Create one (no scopes needed): https://github.com/settings/tokens/new
GITHUB_TOKEN=

# Optional (FREE) — enables the AI City Inspector report and Proposal Coach.
# Create a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
GEMINI_MODEL=
